{
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "api.anthropic.com",
        "localhost",
        "127.0.0.1"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "denyRead": [
        "**/.env*",
        "**/secrets/**",
        "**/*.pem",
        "**/*.key",
        "~/.aws/credentials",
        "~/.ssh"
      ]
    }
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Glob(**/.env*)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Bash(cat **/.env*)",
      "Bash(head **/.env*)",
      "Bash(tail **/.env*)",
      "Bash(less **/.env*)",
      "Bash(more **/.env*)",
      "Bash(open **/.env*)",
      "Bash(grep * **/.env*)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)",
      "Bash(head **/*.pem)",
      "Bash(head **/*.key)",
      "Bash(tail **/*.pem)",
      "Bash(tail **/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-command.sh"
          }
        ]
      }
    ]
  }
}
